<div class="container mt-4">
  <div class="row">
    <div class="col-lg-10 mx-auto">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h1 class="mb-4">Create New Sub-Cliq</h1>
          <div class="d-flex align-items-center mb-4">
            <span class="text-muted me-2">Under:</span>
            
            <div class="d-flex align-items-center">
              <% 
                  # Ancestor filtering logic
                  ancestors = @parent_cliq["ancestors"] || []
                  main_cliq_color = nil

                  if ancestors.any? && ancestors.first["color"].present?
                     main_cliq_color = ancestors.first["color"]
                     # Skip the first ancestor (Main Cliq)
                     ancestors = ancestors.drop(1)
                  elsif @parent_cliq["color"].present?
                     # Fallback if parent itself has color directly (e.g. is a main cliq)
                     main_cliq_color = @parent_cliq["color"]
                  end
              %>

              <% if main_cliq_color.present? %>
                  <div class="rounded-circle me-2" style="width: 8px; height: 8px; background-color: <%= main_cliq_color %>;" title="Theme Color"></div>
              <% end %>

              <% ancestors.each do |ancestor| %>
                  <%= link_to ancestor["name"], cliq_path(ancestor["id"]), class: "fw-bold text-secondary text-decoration-none hover-dark", target: "_blank" %>
                  <span class="mx-1 text-muted">/</span>
              <% end %>

              <%= link_to @parent_cliq["name"], cliq_path(@parent_cliq["id"]), class: "fw-bold text-dark text-decoration-none hover-primary", target: "_blank" %>
            </div>
          </div>

          <% if @errors.present? %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <strong>Error:</strong>
              <ul class="mb-0">
                <% @errors.each do |error| %>
                  <li><%= error %></li>
                <% end %>
              </ul>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% end %>

          <%= form_with(local: true, url: create_child_cliq_path(@parent_cliq["id"].to_i), method: :post) do |form| %>
            <!-- Section 1: Cliq Details -->
            <div class="mb-5">
              <div class="bg-light p-3 rounded mb-3">
                <h5 class="fw-bold mb-0">📁 Cliq Details</h5>
              </div>
              <%= render "form", form: form %>
            </div>

            <hr>

            <!-- Section 2: First Post -->
            <div class="mb-5">
              <div class="bg-light p-3 rounded mb-3">
                <h5 class="fw-bold mb-0">📝 First Post (Kickstart the discussion)</h5>
              </div>
              <%= fields_for :post do |post_form| %>
                <%= render "posts/fields", form: post_form %>
              <% end %>
            </div>

            <div class="d-flex gap-2">
              <%= form.submit "Create Cliq & Post", class: "btn btn-primary btn-lg" %>
              <%= link_to "Cancel", cliq_path(@parent_cliq["id"].to_i), class: "btn btn-secondary btn-lg" %>
            </div>

            <%= render "shared/trix_styles" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
