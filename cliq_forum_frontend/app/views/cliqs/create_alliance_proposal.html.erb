<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm border-info">
        <div class="card-header bg-info-subtle text-info-emphasis d-flex justify-content-between align-items-center">
          <div>
            <h4 class="mb-1">Propose Alliance for "<%= @cliq["name"] %>"</h4>
            <div class="small text-muted d-flex align-items-center">
               <i class="bi bi-people-fill me-1"></i>
               <%= @cliq["hierarchy"] || @cliq["name"] %>
            </div>
          </div>
          <i class="bi bi-link-45deg fs-2"></i>
        </div>
        
        <div class="card-body">
          <div class="alert alert-info mb-4">
            <h5 class="alert-heading"><i class="bi bi-info-circle-fill me-2"></i>What is an Alliance?</h5>
            <p class="mb-0">
              An Alliance allows <strong><%= @cliq["name"] %></strong> to feature content from another Cliq directly in its feed.
              This strengthens the community by sharing relevant discussions without merging or deleting anything.
            </p>
          </div>

          <% if @errors.present? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% @errors.each do |error| %>
                  <li><%= error %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with url: alliance_proposal_cliq_path(@cliq["id"]), method: :post, scope: :proposal, local: true do |f| %>
            
            <!-- Target Category Search/Select -->
            <div class="mb-4" data-controller="cliq-search">
              <label class="form-label fw-bold">Select Ally Category *</label>
              <div class="form-text mb-2">Search for the category you want to ally with.</div>
              
              <div class="input-group">
                <input type="text" class="form-control" placeholder="Search for ally category..." data-cliq-search-target="input" data-action="input->cliq-search#search">
                <button class="btn btn-outline-secondary" type="button" disabled>
                  <i class="bi bi-search"></i>
                </button>
              </div>
              
              <!-- Hidden ID field -->
              <%= f.hidden_field :target_cliq_id, required: true, data: { "cliq-search-target": "idField" } %>
              
              <!-- Results Dropdown -->
              <div class="list-group mt-2 position-absolute shadow-sm w-100 bg-white" style="z-index: 1000; max-height: 200px; overflow-y: auto; display: none;" data-cliq-search-target="results">
                <!-- Javascript will populate this -->
              </div>
              
              <!-- Selected Item Preview -->
              <div class="mt-2 text-success fw-bold p-2 bg-success-subtle rounded d-none" data-cliq-search-target="selectionDisplay">
                <div class="d-flex justify-content-between align-items-center">
                  <span>Selected: <span data-cliq-search-target="selectionName"></span></span>
                  <button type="button" class="btn btn-sm btn-outline-danger ms-2" data-action="click->cliq-search#clear">Change</button>
                </div>
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label fw-bold">Alliance Description *</label>
              <div class="form-text">Explain why this alliance benefits our community. This will be posted as a proposal for voting.</div>
              <%= f.text_area :description, class: "form-control", rows: 4, required: true, placeholder: "e.g. Bringing in news from the global tech feed would render our local discussions more informed..." %>
            </div>

            <div class="d-flex justify-content-end gap-2">
              <%= link_to "Cancel", cliq_path(@cliq["id"]), class: "btn btn-outline-secondary" %>
              <%= f.submit "Submit Alliance Proposal", class: "btn btn-info text-white" %>
            </div>
            
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
