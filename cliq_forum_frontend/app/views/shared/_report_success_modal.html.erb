
<div id="reportModalSuccessTrigger" 
     data-controller="report-success"
     data-action="connect->report-success#show">
</div>

<div class="modal fade" id="reportModal" tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true" data-bs-backdrop="static">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title" id="reportModalLabel"><i class="bi bi-check-circle-fill me-2"></i> Report Submitted</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center py-4">
        <i class="bi bi-check-circle text-success display-1 mb-3"></i>
        <h4>Thank You!</h4>
        <p class="text-muted">
          Your report has been received and will be reviewed by our moderation team shortly.
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
